# ─── Supabase (required) ──────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_anon_key_here

# ─── Copy this file to .env and fill in the values above ──
# The bot reads all other settings (delays, hours, caps)
# from the bot_accounts table in Supabase — no need to set them here.
